	<Folder id="555492DBC6000001">
		<name>Fortifications</name>
		<description><![CDATA[<div>-<a href="https://lesblockhauslyssois-lbl.github.io/livre">Notre livre sur le secteur fortifié de Lille</a><br></div><div><br></div><div>-<a href="https://docs.google.com/document/d/1SI9WIRatdaZ9-VcGJEF-jUFZqRLrupmx2Yhebni83iA/edit?usp=sharing">conditions d'utilisations</a><br></div><div><br></div><div>-<a href="https://docs.google.com/document/d/1y37WLp6-T7huqRnRbDShphgMOylF72E8tf7HQRPZUWs/edit?usp=sharing">explications des indications sur la carte</a><a href="https://docs.google.com/document/d/1y37WLp6-T7huqRnRbDShphgMOylF72E8tf7HQRPZUWs/edit?usp=sharing"></a><br></div><div><br></div><div>-<a href="https://docs.google.com/document/d/1dbSeKAQ10IvF9qD2pTo4jsWeNaaReZBjubhNdePobzI/edit?usp=sharing">explication du Secteur Fortifié de Lille</a><br></div><div><br></div>]]></description>
		<styleUrl>#__managed_style_04E05A570C3E94C458DC</styleUrl>
		<Folder id="075FBAA088387930B329">
			<name>construction BEF</name>
			<styleUrl>#__managed_style_3601EA50203E94C4590F</styleUrl>
			<Placemark id="0AE4AA9D533A2B9868BC">
				<name>BEF 525</name>
				<description><![CDATA[<div>Blockhaus de <a href="https://docs.google.com/document/d/1UsVGD9Hu7AaGy9mkbGxit2K9KrGeveZLgzhYzMK9PKw/edit?usp=sharing">type R</a><a href="https://docs.google.com/document/d/1UsVGD9Hu7AaGy9mkbGxit2K9KrGeveZLgzhYzMK9PKw/edit?usp=sharing"></a><br></div><div><br></div><div>état : disparu<br></div>]]></description>
				<LookAt>
					<longitude>3.285740937299473</longitude>
					<latitude>50.51244908058324</latitude>
					<altitude>42.56688260759463</altitude>
					<heading>0</heading>
					<tilt>0</tilt>
					<gx:fovy>35</gx:fovy>
					<range>128.7734904525132</range>
					<altitudeMode>absolute</altitudeMode>
				</LookAt>
				<styleUrl>#__managed_style_1EC0EFC8C93E94C45910</styleUrl>
				<Point>
